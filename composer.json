{
    "name": "domprojects/codeigniter4-country",
    "description": "Translated country helper for CodeIgniter 4 projects.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "codeigniter4",
        "codeigniter",
        "country",
        "countries",
        "helper",
        "localization"
    ],
    "homepage": "https://github.com/domProjects/codeigniter4-country",
    "support": {
        "issues": "https://github.com/domProjects/codeigniter4-country/issues",
        "source": "https://github.com/domProjects/codeigniter4-country"
    },
    "authors": [
        {
            "name": "domProjects",
            "homepage": "https://github.com/domProjects",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.2",
        "codeigniter4/framework": "^4.7.2"
    },
    "require-dev": {
        "codeigniter4/devkit": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "domProjects\\CodeIgniterCountry\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "domProjects\\CodeIgniterCountry\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "analyze": [
            "Composer\\Config::disableProcessTimeout",
            "phpstan analyse -c phpstan.neon.dist --memory-limit=512M",
            "psalm --config=psalm.xml",
            "rector process --dry-run --config=rector.php"
        ],
        "cs": "php-cs-fixer fix --ansi --verbose --dry-run --diff --config=.php-cs-fixer.dist.php",
        "cs-fix": "php-cs-fixer fix --ansi --verbose --diff --config=.php-cs-fixer.dist.php",
        "test": "phpunit -c phpunit.xml.dist"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    }
}
